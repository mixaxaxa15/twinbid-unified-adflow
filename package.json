{
  "name": "twinbid-atlas-mvp",
  "version": "0.1.0",
  "private": true,
  "description": "TwinBid MVP for testing Atlas Cloud image generation and editing",
  "scripts": {
    "build:builder": "esbuild ./src/builder.js --bundle --outfile=./public/builder.bundle.js --loader:.css=css --minify",
    "prestart": "npm run build:builder",
    "start": "node server.js",
    "dev": "node --watch server.js",
    "test": "node --test"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@fontsource/bebas-neue": "^5.2.7",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/montserrat": "^5.2.8",
    "@fontsource/open-sans": "^5.2.7",
    "@fontsource/oswald": "^5.2.8",
    "@fontsource/playfair-display": "^5.2.8",
    "@fontsource/pt-sans": "^5.2.8",
    "@fontsource/roboto": "^5.2.10",
    "@fontsource/russo-one": "^5.2.7",
    "@fontsource/ubuntu": "^5.2.8",
    "esbuild": "^0.28.1",
    "grapesjs": "^0.23.2",
    "xstate": "^5.32.4"
  }
}
